# public origin used to build short URLs (no trailing slash)
APP_URL=http://localhost:3000

# postgres (compose uses these too)
POSTGRES_USER=shorturl
POSTGRES_PASSWORD=shorturl
POSTGRES_DB=shorturl
DATABASE_URL=postgresql://shorturl:shorturl@db:5432/shorturl?schema=public

# redis
REDIS_URL=redis://redis:6379

# auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me
AUTH_URL=http://localhost:3000

# optional: path to maxmind geolite2 city db inside the container
GEOIP_DB_PATH=/app/data/GeoLite2-City.mmdb
